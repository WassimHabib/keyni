# Application
APP_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info

# Sessions — générer 32+ bytes aléatoires : openssl rand -base64 48
SESSION_SECRET=remplacer-par-un-secret-aleatoire-de-32-octets-minimum-en-prod

# Email : "console" | "resend" | "smtp"
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@keyni.local

# Resend (si EMAIL_PROVIDER=resend)
# RESEND_API_KEY=

# SMTP (si EMAIL_PROVIDER=smtp)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Base de données (non utilisé au démarrage — branché à la phase Postgres)
# DATABASE_URL=postgresql://user:password@localhost:5432/keyni
